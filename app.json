{
  "expo": {
    "name": "Piggy Stash",
    "slug": "budget-app",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "budgetapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.linettekuhn.budgetapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFCEDA",
          "dark": {
            "image": "./assets/images/splash-icon-dark.png",
            "backgroundColor": "#FF9CB5"
          }
        }
      ],
      "expo-sqlite",
      "expo-web-browser",
      "expo-notifications",
      [
        "expo-widgets",
        {
          "src": "widgets",
          "widgets": [
            {
              "name": "BudgetWidget",
              "contentMarginsDisabled": true,
              "displayName": "Budget Left",
              "description": "See your remaining monthly budget at a glance",
              "supportedFamilies": ["systemSmall", "systemMedium"]
            },
            {
              "name": "CategoryWidget",
              "contentMarginsDisabled": true,
              "displayName": "Category Budget",
              "description": "Track spending for a specific category",
              "supportedFamilies": ["systemSmall", "systemMedium"]
            },
            {
              "name": "StreakWidget",
              "contentMarginsDisabled": true,
              "displayName": "Savings Streak",
              "description": "Stay motivated with your current savings streak and badge count",
              "supportedFamilies": ["systemSmall"]
            },
            {
              "name": "AddTransactionWidget",
              "contentMarginsDisabled": true,
              "displayName": "Add Transaction",
              "description": "Quickly jump to adding a new transaction",
              "supportedFamilies": ["systemSmall"]
            }
          ]
        }
      ],
      "expo-local-authentication",
      [
        "expo-background-fetch",
        {
          "backgroundFetchIntervalSeconds": 3600
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3c7619eb-9a8a-402e-b0e7-74789990abea"
      }
    },
    "owner": "linettekuhn",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3c7619eb-9a8a-402e-b0e7-74789990abea"
    }
  }
}
